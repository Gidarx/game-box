# Firebase is optional. When disabled or misconfigured, the game falls back to Tryvia/local questions.
GAMEBOX_FIREBASE_ENABLED=0

# Firestore project/collection used by the server and seed script.
GAMEBOX_FIREBASE_PROJECT_ID=
GAMEBOX_FIREBASE_QUESTIONS_COLLECTION=questions

# Recommended local auth: point GOOGLE_APPLICATION_CREDENTIALS to your service account JSON.
# PowerShell example:
# $env:GOOGLE_APPLICATION_CREDENTIALS="C:\Users\you\Downloads\firebase-service-account.json"
GOOGLE_APPLICATION_CREDENTIALS=

# Alternative for deploys: paste the service-account JSON or base64-encoded JSON into one of these.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=

# AI question generation. The host panel uses the OpenAI Responses API when this is set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Similarity threshold for discarding repeated questions. Lower is stricter.
QUESTION_SIMILARITY_THRESHOLD=0.74
